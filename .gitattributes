# Auto detect text files and perform LF normalization
* text=auto

# Ensure LF line endings on checkout for shell scripts and source files
*.js text eol=lf
*.mjs text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Treat binary files appropriately
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.mp4 binary
*.mp3 binary
*.db binary
*.wasm binary
